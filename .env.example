# ── Required ─────────────────────────────────────────────────
SWAGGER_PATH=https://petstore3.swagger.io/api/v3/openapi.json
SWAGGER_BASE_URL=https://petstore3.swagger.io/api/v3
UPSTREAM_ALLOWED_HOSTS=petstore3.swagger.io

# ── Transport (stdio | streamable) ──────────────────────────
# TRANSPORT=streamable                # default in Docker: streamable
# HTTP_PORT=8080                      # host port mapping
# LOG_LEVEL=info

# ── Inbound OAuth (required for streamable) ─────────────────
# Provide JWKS *or* Introspection URL — at least one is needed.
INBOUND_OAUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
INBOUND_OAUTH_ISSUER=https://issuer.example.com
INBOUND_OAUTH_AUDIENCE=mcp-api
# INBOUND_OAUTH_REQUIRED_SCOPES=mcp:tools.call

# ── Policy ───────────────────────────────────────────────────
# MCP_API_MODE=plan_only             # plan_only | execute_readonly | execute_write | sandbox
# UPSTREAM_BASE_URL=
# ALLOWED_METHODS=GET,HEAD,OPTIONS
# DENIED_METHODS=DELETE
# BLOCK_PRIVATE_NETWORKS=true

# ── Upstream auth (to real API) ──────────────────────────────
# UPSTREAM_AUTH_MODE=none             # none | static_bearer | api_key | oauth_client_credentials
# UPSTREAM_BEARER_TOKEN=
# UPSTREAM_API_KEY_HEADER=X-API-Key
# UPSTREAM_API_KEY_VALUE=

# ── Limits ───────────────────────────────────────────────────
# MAX_CALLS_PER_MINUTE=60
# MAX_CONCURRENT_CALLS=10
# HTTP_TIMEOUT=30s

# ── Audit / CORS ─────────────────────────────────────────────
# AUDIT_LOG=true
# CORS_ALLOWED_ORIGINS=
